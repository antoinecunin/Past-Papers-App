# API
API_PORT=3000
API_LOG_LEVEL=info
API_HEALTH_PATH=/api/health
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Mongo
MONGO_URI=mongodb://mongo:27017/annales
MONGO_RETRY_MS=2000
MONGO_MAX_RETRIES=60

# MinIO
S3_ENDPOINT=minio:9000
S3_REGION=us-east-1
S3_BUCKET=annales
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminsecret
S3_USE_SSL=false

# Build
NODE_ENV=production